<div class="wrapper">
  <div class="payment">
<!--     <div class="payment-logo">
      <img class="logo" src="./assets/images/logo.png">
    </div> -->

    
    <h2>Pay Your Bill</h2>
    <div class="form">
      <form method="post" name="customer-data" action="/pay-alternate">
       
        <!-- hidden uuid -->
        <input type="hidden" name="uuid" value="<%= uuid %>">
       
        <div class="card space icon-relative">
          <label class="label">Statement Code:</label>
          <input type="text" name="Code" disabled class="input" id="statement" value="<%= patientId %>" data-mask="AAAA AAAA AAAA AAA" placeholder="XXXX XXXX XXXX XXX" minlength="15" maxlength="15" required>
          <i class="fas fa-hashtag"></i>

          
        </div>

        <div class="mb-2">

          <a href="#" id="modal_trigger" class="text-blue-600 hover:text-blue-800 font-semibold">Where can I find my code?</a>
      </div>
        <div class="card space icon-relative">
          <label class="label">Phone number:</label>
          <input type="text" name="Phone" pattern="\d*" disabled value="<%= phoneNo %>" inputmode="numeric" class="input" id="phone" placeholder="Enter your Phone Number"  minlength="9" maxlength="12" required>
          <i class="fas fa-phone"></i>
        </div>

        <div class="card space icon-relative">
          <label class="label">Amount:</label>
          <input type="number" name="Amount" readonly class="input" id="amount" value="<%= amount %>" placeholder="Enter Amount"   minlength="1" maxlength="12" required>
          <i class="fas fa-dollar-sign"></i>
        </div>
       
        <div class="card space icon-relative">
        <label class="label">Card holder name:</label>
        <input type="text" class="input" name="Name" placeholder="Bruce Wayne" required>
        <i class="fas fa-user"></i>
      </div>
	 <div class="card space icon-relative">
        <label class="label">Card number:</label>
        <input type="text" name="Card" class="input" id="card-data" data-mask="0000 0000 0000 0000" placeholder="XXXX XXXX XXXX XX86" minlength="16" required>
        <i class="far fa-credit-card"></i>
      </div>
      <div class="card-grp space">
        <div class="card-item icon-relative">
          <label class="label">Expiry date:</label>
          <input type="text" name="Expiry" class="input" data-mask="00 / 00"  placeholder="00 / 00" required>
          <i class="far fa-calendar-alt"></i>
        </div>
        <div class="card-item icon-relative">
          <label class="label">CVC:</label>
          <input type="text" name="CVV" class="input" data-mask="0000" placeholder="000" required>
          <i class="fas fa-lock"></i>
        </div>
      </div>
      
      <div class="card space icon-relative">
        <label class="label">Street Address:</label>
        <input type="text" name="StreetAddress" class="input" placeholder="123 Main Street" required>
        <i class="fas fa-map-marker-alt"></i>
      </div>

      <div class="card-grp space">
        <div class="card-item icon-relative">
          <label class="label">City:</label>
          <input type="text" name="City" class="input" placeholder="New York" required>
          <i class="fas fa-city"></i>
        </div>
        <div class="card-item icon-relative">
          <label class="label">State:</label>
          <input type="text" name="State" class="input" placeholder="NY" required>
          <i class="fas fa-map"></i>
        </div>
      </div>

    
        <div class="card icon-relative">
          <label class="label">Zip Code:</label>
          <input type="text" name="ZipCode" class="input" placeholder="10001" required>
          <i class="fas fa-envelope"></i>
        </div>
      
      <br>
      <div class="wrap">
        <center>
            <input type="submit" name="submit" class="btn" value="Pay" />
        </center>
      </div>
      
    </form>
      <div class="image"><img src="cclogos.png"></div>
    </div>
  </div>
</div>

<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content" style="width: 100%">
        <div class="modal-header">
          <h5 class="modal-title" id="exampleModalLabel">Find Your Code</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">X</button>
        </div>
        <div class="modal-body">
            <p>We'll need your statement code to identify you. You can find it on your statement as shown below:
            </p>
          <img src="new_statement_code.1626e06b.png" alt="" style="width: 90%;">
        </div>
      </div>
    </div>
  </div>
        

	<script src="https://code.jquery.com/jquery-3.3.1.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.15/jquery.mask.min.js"></script>
     <!-- Option 1: Bootstrap Bundle with Popper -->
     <script src="https://cdn.tailwindcss.com"></script>
     <!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script> -->

     <script>
      document.addEventListener('DOMContentLoaded', () => {
        const input = document.getElementById('phone');
        if (input) {
          input.addEventListener('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '');
          });
        }
    
        const modalTrigger = document.getElementById('modal_trigger');
        const modal = document.getElementById('exampleModal');
    
        if (modalTrigger && modal) {
          modalTrigger.addEventListener('click', () => {
            openModal();
          });
        }
    
        function openModal() {
          modal.style.display = 'flex';
        }
    
        function closeModal() {
          modal.style.display = 'none';
        }
    
        // Optional: bind close button (if exists)
        const modalClose = document.getElementById('modal_close');
        if (modalClose) {
          modalClose.addEventListener('click', () => {
            closeModal();
          });
        }
      });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const expiryInput = document.querySelector('input[name="Expiry"]');
            
            if (expiryInput) {
                expiryInput.addEventListener('blur', function() {
                    validateExpiryDate(this);
                });
                
                expiryInput.addEventListener('change', function() {
                    validateExpiryDate(this);
                });
            }
        });

        function validateExpiryDate(input) {
            const value = input.value.trim();
            
            if (!value) return;
            
            const parts = value.split('/').map(p => p.trim());
            if (parts.length !== 2) {
                input.classList.add('is-invalid');
                alert('Invalid expiry date format. Use MM / YY');
                input.value = '';
                return;
            }
            
            const month = parseInt(parts[0], 10);
            const year = parseInt(parts[1], 10);
            
            if (isNaN(month) || isNaN(year) || month < 1 || month > 12) {
                input.classList.add('is-invalid');
                alert('Invalid month. Please enter a valid month (01-12)');
                input.value = '';
                return;
            }
            
            const currentDate = new Date();
            const currentYear = currentDate.getFullYear() % 100;
            const currentMonth = currentDate.getMonth() + 1;
            
            const cardYear = year;
            const cardMonth = month;
            
            if (cardYear < currentYear || (cardYear === currentYear && cardMonth < currentMonth)) {
                input.classList.add('is-invalid');
                alert('Card has expired. Please enter a valid expiry date');
                input.value = '';
                return;
            }
            
            input.classList.remove('is-invalid');
            input.classList.add('is-valid');
        }
    </script>
    
</body>
