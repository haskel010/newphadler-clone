}

#loader::before {
  content: "";
  display: block;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 4px solid #ccc;
  border-top-color: #3498db; /* set the color of the spinning animation */
  animation: spin 0.8s linear infinite; /* add the spinning animation */
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

