<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Payment - Enter Amount</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body {
        background: #2563eb; /* Tailwind blue-600 */
      }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center" style="background: #2563eb;">
    <div class="w-full max-w-md mx-auto">
        <div class="bg-white rounded-lg shadow-xl p-8">
            <h4 class="mb-3 text-blue-600 text-xl font-bold">Pay your Bill</h4>
            <p class="mb-6 text-gray-700">Please enter amount to proceed </p>
            <form id="paymentForm" method="POST" action="/paynow-alternate" class="space-y-5">
                <div>
                    <label for="code" class="block text-gray-700 font-semibold mb-1">Payment Code</label>
                    <input type="text" class="input w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-100 tracking-widest" id="code" name="code" value="<%= code.replace(/(.{4})(.{4})(.{4})(.{3})/, '$1-$2-$3-$4') %>" readonly required>
                </div>
                <!-- hidden uuid field -->
                <input type="hidden" name="uuid" value="<%= uuid %>">
                <div>
                    <label for="amount" class="block text-gray-700 font-semibold mb-1">Payment Amount</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 text-lg">$</span>
                        <input type="number" class="input w-full pl-9 pr-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" id="amount" name="amount" min="1" step="any" required>
                    </div></div>

                    <div>
                        <label for="phone" class="block text-gray-700 font-semibold mb-1">Phone Number</label>
                        <div class="flex flex-row gap-0">
                            <span class="inline-flex items-center px-4 py-2 border border-gray-300 border-r-0 rounded-l bg-gray-100 text-gray-700 font-semibold">+1</span>
                            <input type="tel" class="input w-full px-4 py-2 border border-gray-300 rounded-r focus:outline-none focus:ring-2 focus:ring-blue-500" id="phone" name="phone" required pattern="[0-9\-\(\)\s]+" placeholder="(123) 456-7890">
                        </div>


                           
                    </div>
                <button type="submit" class="btn mt-2 w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 rounded transition">Proceed</button>
             
            </form>
        </div>
    </div>
    <!-- <script>
        document.getElementById('paymentForm').onsubmit = function(e) {
            e.preventDefault();
            const form = e.target;
            const params = new URLSearchParams({
                code: form.code.value,
                amount: form.amount.value,
                phone: form.phone.value.trim()
            });
            window.location.href = `/payment-failed?${params.toString()}`;
        };
    </script> -->
    
    <script>
    const phoneInput = document.getElementById('phone');

    phoneInput.addEventListener('input', function () {
        // Allow only these characters in typing
        let cleaned = this.value.replace(/[^0-9\(\)\-\s]/g, '');

        // Extract digits only
        let digits = cleaned.replace(/\D/g, '');

        // Prevent entering more than 10 digits
        if (digits.length > 10) {
            digits = digits.slice(0, 10);
        }

        // Optional: auto-format into (123) 456-7890
        let formatted = "";
        if (digits.length > 0) formatted = "(" + digits.slice(0, 3);
        if (digits.length > 3) formatted += ") " + digits.slice(3, 6);
        if (digits.length > 6) formatted += "-" + digits.slice(6, 10);

        // Set formatted or raw digits depending on length
        this.value = formatted;

        // Visible max length limit
        if (this.value.length > 14) {
            this.value = this.value.slice(0, 14);
        }
    });

    document.getElementById('paymentForm').addEventListener('submit', function (e) {
        const digits = phoneInput.value.replace(/\D/g, '');

        if (digits.length !== 10) {
            e.preventDefault();
            alert('Please enter a valid 10-digit US phone number.');
        }
    });
</script>

</body>
</html>