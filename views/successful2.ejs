  <style>
    body {
      background: #f2f2f2;
      font-family: "Roboto", sans-serif;
    }
    
    .card {
      max-width: 400px;
      margin: 50px auto;
      padding: 22px;
      background: #fff;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
      text-align: center;
      min-height: 440px;
    }
    
    .card-heading {
      font-size: 24px;
      color: #00b894;
      margin-bottom: 20px;
    }
    
    .tick-icon {
      display: flex;
      justify-content: center;
      align-items: center;
      margin-bottom: 20px;
      color: #00b894;
      font-size: 40px;
      border: 2px solid #00b894;
      border-radius: 50%;
      height: 80px;
      width: 80px;
      margin: 0 auto 20px;
    }
    
    .details {
      margin-bottom: 20px;
      text-align: left;
    }
    
    .details p {
      margin-bottom: 10px;
      display: flex;
      justify-content: space-between;
    }
    
    .button {
      display: inline-block;
      padding: 10px 20px;
      margin-right: 10px;
      font-weight: bold;
      cursor: pointer;
      transition: background-color 0.3s;
      background-color: transparent;
      color: #fff;
      border: none;
    }
    
    .button-print {
      background-color: #33b5e5;
    }
    
    .button-download {
      background-color: #00b894;
    }
    
    .button-close {
      background-color: #ff4444;
    }
  </style>
  <script src="https://unpkg.com/easyinvoice/dist/easyinvoice.min.js"></script>
