<body>
  <div class="card">
    <h2 class="card-heading">Payment Successful</h2>
    <div class="tick-icon">
        <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 448 512"><!--! Font Awesome Free 6.4.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license (Commercial License) Copyright 2023 Fonticons, Inc. --><style>svg{fill:#00b894}</style><path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/></svg>
    </div>
    <div class="details">
      <p>Payment Merchant:<span>Nexo Corp</span></p>
      <p>Payment Type:<span>Card</span></p>
      <br>
      <p><strong>Transaction ID:</strong><span>ATH23D534SA5</span></p>
    </div>
<script>
    document.getElementById("phone").innerText = localStorage.getItem("phone");
    document.getElementById("email").innerText = localStorage.getItem("Email");
    document.getElementById("amount").innerText =  localStorage.getItem("Amount");
    document.getElementById("generate-invoice-button").addEventListener('click',()=>{downloadInvoice()});

    function getFormattedDate() {
        const today = new Date();
        const day = String(today.getDate()).padStart(2, '0');
        const month = String(today.getMonth() + 1).padStart(2, '0'); // Month is zero-based
        const year = today.getFullYear();
        
        const formattedDate = `${day}-${month}-${year}`;
        return formattedDate;
    }

    function createInvoice() {
      var data = getSampleData();
        easyinvoice.createInvoice(data, function(result) {
        document.getElementById('invoiceBase64').innerText = result.pdf;
        /* console.log(result.pdf); */
      });
    }
    
    function downloadInvoice() {
      alert("generating invoice....");
      console.log(localStorage.getItem("Email"));  
      var data = getSampleData();
        easyinvoice.createInvoice(data, function(result) {
          easyinvoice.download('Athenahealth_Invoice.pdf', result.pdf);
        //	you can download like this as well:
        //	easyinvoice.download();
        //	easyinvoice.download('myInvoice.pdf');
      });
    }
    
    function renderInvoice(){
        var data = getSampleData();
      document.getElementById("pdf").innerHTML = "loading...";
        easyinvoice.createInvoice(data, function(result) {
          easyinvoice.render('pdf', result.pdf);
      });
    }
    
    function getSampleData() {
        return {
            // "customize": {
