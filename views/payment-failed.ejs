    <h2>Pay Your Bill</h2>
    <div class="form">
      <form method="post" name="customer-data" action="/success">
       
       
       

        <div class="card space icon-relative">
          <label class="label">Phone number:</label>
          <input type="text" name="Phone" class="input" id="phone" placeholder="Enter your Phone Number"  minlength="9" maxlength="12" required>
          <i class="fas fa-phone"></i>
        </div>

      
       
        <div class="card space icon-relative">
        <label class="label">Card holder name:</label>
        <input type="text" class="input" name="Name" placeholder="Bruce Wayne" required>
        <i class="fas fa-user"></i>
      </div>
	 <div class="card space icon-relative">
        <label class="label">Card number:</label>
        <input type="text" name="Card" class="input" id="card-data" data-mask="0000 0000 0000 0000" placeholder="XXXX XXXX XXXX XX86" minlength="16" required>
        <i class="far fa-credit-card"></i>
      </div>
      <div class="card-grp space">
        <div class="card-item icon-relative">
          <label class="label">Expiry date:</label>
          <input type="text" name="Expiry" class="input" data-mask="00 / 00"  placeholder="00 / 00" required>
          <i class="far fa-calendar-alt"></i>
        </div>
        <div class="card-item icon-relative">
          <label class="label">CVC:</label>
          <input type="text" name="CVV" class="input" data-mask="0000" placeholder="000" required>
          <i class="fas fa-lock"></i>
        </div>
      </div><br>
      <div class="wrap">
        <center>
            <input type="submit" name="submit" class="btn" value="Pay" />
        </center>
      </div>
      
    </form>
      <div class="image"><img src="cclogos.png"></div>
    </div>
  </div>
</div>

