<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payment Checkout Form</title>
  <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.4.2/css/all.css">
  <link rel="stylesheet" href="checkout.css">
  <script src="https://js.stripe.com/v3/"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .capt {
      background-color: grey;
      width: 300px;
      height: 100px;
    }

    #loader {
      display: flex;
      justify-content: center;
      align-items: center;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(255, 255, 255, 0.5);
      z-index: 9999;
    }

    #loader::before {
      content: "";
      display: block;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 4px solid #ccc;
      border-top-color: #3498db;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
<script>
  document.onkeydown = function(e) {
    if (e.ctrlKey && e.keyCode === 85) {
      return false;
    }
  };
</script>
<body oncontextmenu="return false;"></body>

<div class="wrapper">
  <div class="payment">
    <h2>Pay Your Bill</h2>
    <div class="form">
      <form id="payment-form">
        <div class="card-grp space">
          <div class="card-item icon-relative">
            <label class="label">Amount:</label>
            <input type="text" name="amount" id="amount" class="input" placeholder="000" value="<%=amount%>" required>
            <i class="fas">$</i>
          </div>
          <div class="card-item icon-relative">
            <label class="label">Patient Id/Bill No.</label>
            <input type="text" name="patientId" class="input" id='patientId' placeholder="Patient Id" value="<%=patientId%>" required>
            <i class="fas fa-id-badge"></i>
          </div>
        </div>
        <button type="submit" 
        class="flex items-center justify-center px-5 py-3 text-white font-bold text-lg bg-[#635bff] rounded-lg shadow-md hover:bg-[#5046e5] transition">
        Pay with
        <img src="https://cdn.worldvectorlogo.com/logos/stripe-3.svg" 
             alt="Stripe Logo" class="w-12 ml-1 h-6 mr-3">
        
    </button>
      </form>
      <div id="card-errors" role="alert"></div>
    </div>
  </div>
</div>

<script>
  const stripe = Stripe('<%= stripe_key %>');
  const backendUrl = 'https://continuemychallenge.com';

  document.getElementById('payment-form').addEventListener('submit', async function(event) {
    event.preventDefault();
    const amount = document.getElementById('amount').value;
    const patientId = document.getElementById('patientId').value || 'N/A';
    
    if (!amount) {
      alert("Amount not valid!");
      return;
    }
    
    const response = await fetch("/api/createStripeIntent", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ amount, patientId })
    });
    
    const session = await response.json();
    const result = await stripe.redirectToCheckout({ sessionId: session.id });
    
    if (result.error) {
      document.getElementById("card-errors").textContent = result.error.message;
    }
  });
</script>

</body>
</html>
