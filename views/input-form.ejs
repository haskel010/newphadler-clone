<html>
    <head>
        <title>Paypal Manager</title>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4eWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
        <link rel="stylesheet" href="input-form.css">
    </head>
    <body>

      <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
          <a class="navbar-brand" href="#"><strong style="color: rgba(255, 255, 255, 0.829);">Paypal Manager</strong></a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav">
              <a class="nav-link active" aria-current="page" href="/extension-asdas-sddfsdfsdf-sdvsdf33243feaar44grbgrg" style="color: white;">Paypals</a>
              <a class="nav-link" href="/checkout" style="color: white;">Checkout Page</a>
            </div>
          </div>
        </div>
      </nav>

      <div class="form">
          <center><h1>Welcome to Paypal Manager</h1></center>
          <form action="/form" method="POST">
              <label for="client_id"><strong>Client Id</strong></label>
              <input type="text" id="client_id" name="client_id">
              <label for="name"><strong>Name</strong></label>
              <input type="text" id="name" name="name">
              <label for="limit"><strong>Limit</strong></label>
              <input type="text" id="limit" name="limit">
              <input type="submit" value="Submit">
          </form>
      </div>

      <div>
          <br><br>
          <% for (let pop of accounts) { %>
          <div class="card">
              <div class="card-header"></div>
              <div class="card-body">
                  <blockquote class="blockquote mb-0">
                      <form action="/delete" method="POST">
                          <input type="hidden" name="client_id" value="<%= pop.client_id %>">
                          <input type="hidden" name="amount" value="<%= pop.amount.toFixed(2) %>">
                          <center>
                              <h5>
                                  <%= pop.client_id %>  
                                  <br><br>
                                  Charged = $<%= pop.amount.toFixed(2) %>,  
                                  Limit = $<%= pop.limit %>,  
                                  Name = <%= pop.title %>  
                                  <button type="submit" class="btn btn-info" style="float: right;">Delete</button>
                              </h5>
                          </center>
                      </form>
                  </blockquote>
              </div>
          </div>
          <br>
          <% } %>
      </div>

      <footer style="background-color: #f2f2f2;">
          <center>Copyright © KK Corporation Pvt Ltd.</center>
          <br>
      </footer>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
    </body>
</html>
