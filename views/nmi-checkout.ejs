<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NMI Payment Checkout</title>
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.4.2/css/all.css">
    <link rel="stylesheet" href="checkout.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }

        .wrapper {
            width: 100%;
            max-width: 500px;
            padding: 20px;
        }

        .payment {
            background: white;
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        }

        .payment h2 {
            text-align: center;
            color: #333;
            margin: 0 0 10px 0;
            font-size: 28px;
            font-weight: 600;
        }

        .payment-subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 14px;
        }

        .payment-details {
            background: #f9f9f9;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 30px;
            border-left: 4px solid #0066cc;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .detail-row:last-child {
            margin-bottom: 0;
        }

        .detail-label {
            color: #666;
            font-weight: 500;
        }

        .detail-value {
            color: #333;
            font-weight: 600;
        }

        .amount-total {
            display: flex;
            justify-content: space-between;
            padding-top: 12px;
            border-top: 1px solid #e0e0e0;
            margin-top: 12px;
            font-size: 16px;
            font-weight: 700;
            color: #0066cc;
        }

        .checkout-button {
            width: 100%;
            padding: 14px 24px;
            font-size: 16px;
            font-weight: 600;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #0066cc 0%, #004999 100%);
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 102, 204, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .checkout-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 102, 204, 0.4);
        }

        .checkout-button:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .checkout-button i {
            font-size: 18px;
        }

        .security-info {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: #999;
        }

        .security-info i {
            color: #0066cc;
            margin-right: 4px;
        }

        .loading-spinner {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .loading-spinner.active {
            display: flex;
        }

        .spinner-content {
            background: white;
            padding: 40px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #0066cc;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .spinner-text {
            color: #333;
            font-size: 16px;
            font-weight: 600;
        }

        .cc-logos {
            text-align: center;
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
        }

        .cc-logos img {
            height: 32px;
            margin: 0 10px;
            opacity: 0.6;
        }
    </style>
</head>
<body oncontextmenu="return false;">
    <script>
        document.onkeydown = function(e) {
            if (e.ctrlKey && e.keyCode === 85) {
                return false;
            }
        };
    </script>

    <!-- Loading Spinner -->
    <div class="loading-spinner" id="loadingSpinner">
        <div class="spinner-content">
            <div class="spinner"></div>
            <div class="spinner-text">Processing Payment...</div>
        </div>
    </div>

    <div class="wrapper">
        <div class="payment">
            <h2>Complete Your Payment</h2>
            <p class="payment-subtitle">Secure payment powered by NMI</p>

            <div class="payment-details">
                <div class="detail-row">
                    <span class="detail-label">Patient ID/Bill #:</span>
                    <span class="detail-value"><%= patientId %></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Transaction ID:</span>
                    <span class="detail-value"><%= uuid %></span>
                </div>
                <div class="amount-total">
                    <span>Total Amount:</span>
                    <span>$<%= amount %></span>
                </div>
            </div>

            <button class="checkout-button" id="checkoutBtn">
                <i class="fas fa-lock"></i>
                Proceed to Checkout
            </button>

            <div class="security-info">
                <i class="fas fa-shield-alt"></i>
                Secure payment gateway - Your information is encrypted and safe
            </div>

            <div class="cc-logos">
                <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 48 32'%3E%3Crect width='48' height='32' rx='4' fill='%231A1F71'/%3E%3Ctext x='24' y='20' text-anchor='middle' fill='white' font-size='12' font-weight='bold'%3EVISA%3C/text%3E%3C/svg%3E" alt="Visa">
                <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 48 32'%3E%3Crect width='48' height='32' rx='4' fill='%23EB001B'/%3E%3Ccircle cx='16' cy='16' r='8' fill='%23FF5F00'/%3E%3Ccircle cx='32' cy='16' r='8' fill='%23FFB81C'/%3E%3C/svg%3E" alt="Mastercard">
                <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 48 32'%3E%3Crect width='48' height='32' rx='4' fill='%23006FCF'/%3E%3Ctext x='24' y='20' text-anchor='middle' fill='white' font-size='10' font-weight='bold'%3EAMEX%3C/text%3E%3C/svg%3E" alt="American Express">
                <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 48 32'%3E%3Crect width='48' height='32' rx='4' fill='%23FF6000'/%3E%3Ctext x='24' y='20' text-anchor='middle' fill='white' font-size='9' font-weight='bold'%3EDISCOVER%3C/text%3E%3C/svg%3E" alt="Discover">
            </div>
        </div>
    </div>

    <!-- NMI Collect Checkout Script -->
    <script src="https://paymentcloud.transactiongateway.com/token/CollectCheckout.js" data-checkout-key="<%= checkoutKey %>"></script>

    <script>
        const amount = '<%= amount %>';
        const patientId = '<%= patientId %>';
        const uuid = '<%= uuid %>';
        const checkoutBtn = document.getElementById('checkoutBtn');
        const loadingSpinner = document.getElementById('loadingSpinner');

        // Get the base URL (domain) from the current page
        const baseUrl = window.location.origin;

        checkoutBtn.addEventListener('click', function(e) {
            e.preventDefault();

            // Show loading spinner
            loadingSpinner.classList.add('active');
            checkoutBtn.disabled = true;

            try {
                // Determine if we're on localhost or production
                const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
                
                // For NMI CollectCheckout, we need HTTPS URLs
                // If localhost, show a warning and use the base URL as-is
                // If production, ensure HTTPS
                let successUrl, cancelUrl;
                
                if (isLocalhost) {
                    // For localhost testing, we'll construct the URLs but note that NMI requires HTTPS
                    // You may need to use ngrok or update your domain in keys.js
                    successUrl = `https://majorie-ideomotor-claude.ngrok-free.dev/successful/${uuid}`;
                    cancelUrl = `https://majorie-ideomotor-claude.ngrok-free.dev/payment-failed?uuid=${uuid}&gateway=nmi`;
                    
                    console.warn('⚠️ WARNING: NMI Collect Checkout requires HTTPS URLs.');
                    console.warn('For localhost testing, please use ngrok or update DOMAIN_NAME in keys.js to a valid HTTPS URL.');
                } else {
                    // Production - use HTTPS
                    successUrl = `https://${window.location.host}/successful/${uuid}`;
                    cancelUrl = `https://${window.location.host}/payment-failed?uuid=${uuid}&gateway=nmi`;
                }

                // Build line items - NMI only accepts: sku, quantity, amount
                // amount is in cents (smallest currency unit)
                const lineItems = [
                    {
                        sku: patientId || 'PAYMENT-001',
                        quantity: 1,
                        amount: Math.round(parseFloat(amount) * 100) // Convert to cents
                    }
                ];

                // Redirect to NMI Collect Checkout
                CollectCheckout.redirectToCheckout({
                    lineItems: lineItems,
                    successUrl: successUrl,
                    cancelUrl: cancelUrl
                }).then((error) => {
                    if (error) {
                        console.error('Checkout Error:', error);
                        loadingSpinner.classList.remove('active');
                        checkoutBtn.disabled = false;
                        alert('Failed to initiate checkout: ' + (error.message || 'Unknown error'));
                    }
                }).catch((err) => {
                    console.error('Checkout Exception:', err);
                    loadingSpinner.classList.remove('active');
                    checkoutBtn.disabled = false;
                    alert('An error occurred. Please try again.');
                });
            } catch (err) {
                console.error('Error:', err);
                loadingSpinner.classList.remove('active');
                checkoutBtn.disabled = false;
                alert('Something went wrong. Please try again.');
            }
        });

        // Prevent double-click submission
        checkoutBtn.addEventListener('dblclick', function(e) {
            e.preventDefault();
        });
    </script>
</body>
</html>
