<div class="wrapper">
  <div class="payment">
<!--     <div class="payment-logo">
      <img class="logo" src="./assets/images/logo.png">
    </div> -->

    
    <h2>Pay Your Bill</h2>
    <div class="form">
      <form method="post" name="customer-data" action="/paynow">
       <div class="card-grp space">
        <div class="card-item icon-relative">
          <label class="label">Amount:</label>
          <input type="text" name="Amount" id = "amount" class="input"  value = "<%=amount%>" placeholder="000" required readonly>
          <i class="fas">$</i>
        </div>
        <div class="card-item icon-relative">
            <p class="label" style="align-self: center;"><br>This is the total due amount!</p>
          </div>
      </div>
      
      <input type="hidden" name="uuid" value="<%=uuid%>">
      <div class="card icon-relative" style="border: none; background-color: inherit;">
        <label class="label">Statement Code</label>
        <input type="text" class="input" name="PateintId" id = 'patientId' value = "<%=patientId%>" data-mask="AAAA-AAAA-AAA-AAAA" placeholder="XXXX-XXXX-XXX-XXXX" minlength="18" required readonly >
        <i class="fas fa-id-badge"></i>
      </div>
      <br><div class="card icon-relative" style="border: none; background-color: inherit;">
        <label class="label">Phone Number:</label>
        <input type="text" class="input" name="Phone" data-mask="+1 000-000-0000" placeholder="+1 000-000-0000" required>
        <i class="fas fa-phone"></i>
      </div><br>
      <div class="wrap">
        <center>
            <input type="submit" name="submit" class="btn" value="Pay" />
        </center>
      </div>
      
    </form>
    </div>
  </div>
</div>

<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content" style="width: 100%">
        <div class="modal-header">
          <h5 class="modal-title" id="exampleModalLabel">Find Your Code</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">X</button>
        </div>
        <div class="modal-body">
            <p>We'll need your statement code to identify you. You can find it on your statement as shown below:
            </p>
          <img src="new_statement_code.1626e06b.png" alt="" style="width: 90%;">
        </div>
      </div>
    </div>
  </div>


<script>
document.addEventListener('DOMContentLoaded', function() {
  const inputField = document.getElementById('patientId');
  // Add a custom validation message when the input is too short
  inputField.addEventListener('input', function() {
    const inputValue = inputField.value.trim();
    if (inputValue.replace(/\s/g, '').length < 18) {
      inputField.setCustomValidity('please enter your statement code of 15 characters');
    } else {
      inputField.setCustomValidity('');
    }
  });
});
</script>

<script>
  const form = document.forms["customer-data"];
  const urlParams = new URLSearchParams(window.location.search);
  const ref = urlParams.get("ref");

  if (ref) {
      form.action = "/paynow?ref=" + encodeURIComponent(ref);
  }
</script>

<script>
   document.getElementById('patientId').addEventListener('paste', function (event) {
      event.preventDefault();
      const clipboardData = event.clipboardData || window.clipboardData;
      const pastedText = clipboardData.getData('text');
      const uppercasedText = pastedText.toUpperCase();
      document.execCommand('insertText', false, uppercasedText);
      const inputField = document.getElementById('patientId');
      inputField.value = inputField.value.toUpperCase();
    });

    document.getElementById('patientId').addEventListener('input', function () {
      const inputField = document.getElementById('patientId');
      inputField.value = inputField.value.toUpperCase();
    });

	function toggleInput() {
            var paymentInput = document.getElementById("amount");
            var checkbox = document.getElementById("partialPaymentCheckbox");

            if (checkbox.checked) {
                paymentInput.removeAttribute("readonly");
            } else {
                paymentInput.setAttribute("readonly", true);
            }
        }
</script>
        

