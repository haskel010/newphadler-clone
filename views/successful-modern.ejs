<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Successful</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f2f2f2;
            font-family: "Roboto", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            max-width: 450px;
            width: 100%;
        }

        .card {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            animation: slideUp 0.5s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card-header {
            background: #fff;
            padding: 30px;
            text-align: center;
            border-bottom: 1px solid #f0f0f0;
        }

        .success-icon {
            width: 70px;
            height: 70px;
            background: #f0fdf4;
            border: 2px solid #00b894;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0 auto 15px;
            font-size: 36px;
            color: #00b894;
            animation: scaleIn 0.5s ease-out;
        }

        @keyframes scaleIn {
            from {
                transform: scale(0);
            }
            to {
                transform: scale(1);
            }
        }

        .card-heading {
            font-size: 26px;
            font-weight: 600;
            color: #00b894;
            margin: 0;
        }

        .card-subheading {
            font-size: 13px;
            color: #666;
            margin-top: 6px;
        }

        .card-body {
            padding: 30px;
        }

        .details-grid {
            display: grid;
            gap: 12px;
            margin-bottom: 20px;
        }

        .detail-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #f5f5f5;
            font-size: 14px;
        }

        .detail-label {
            color: #666;
            font-weight: 500;
        }

        .detail-value {
            color: #333;
            font-weight: 500;
            text-align: right;
            word-break: break-word;
        }

        .amount-highlight {
            background: #f9f9f9;
            padding: 18px;
            border-radius: 8px;
            border-left: 3px solid #00b894;
            margin: 20px 0;
            text-align: center;
        }

        .amount-label {
            color: #666;
            font-size: 12px;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .amount-value {
            font-size: 32px;
            font-weight: 700;
            color: #00b894;
        }

        .button-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin: 25px 0;
        }

        .btn {
            padding: 11px 14px;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn i {
            font-size: 14px;
        }

        .btn-print {
            background: #33b5e5;
            color: white;
        }

        .btn-print:hover {
            background: #2fa3d1;
        }

        .btn-download {
            background: #00b894;
            color: white;
        }

        .btn-download:hover {
            background: #009a78;
        }

        .btn-close {
            background: #ff4444;
            color: white;
            grid-column: 1 / -1;
        }

        .btn-close:hover {
            background: #e63333;
        }

        .notice {
            background: #fffbf0;
            border-left: 3px solid #ff9800;
            padding: 14px;
            border-radius: 6px;
            font-size: 12px;
            color: #555;
            line-height: 1.6;
            margin-top: 20px;
        }

        .notice strong {
            color: #333;
            display: block;
            margin-bottom: 6px;
        }

        .notice a {
            color: #00b894;
            text-decoration: none;
            font-weight: 600;
        }

        @media (max-width: 480px) {
            .card-body {
                padding: 20px;
            }

            .card-heading {
                font-size: 22px;
            }

            .amount-value {
                font-size: 28px;
            }

            .detail-item {
                font-size: 13px;
            }
        }
    </style>
    <script src="https://unpkg.com/easyinvoice/dist/easyinvoice.min.js"></script>
    <script type="text/javascript">
        var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
        (function(){
            var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
            s1.async=true;
            s1.src='https://embed.tawk.to/64b02a6f94cf5d49dc6363ff/1h582bjut';
            s1.charset='UTF-8';
            s1.setAttribute('crossorigin','*');
            s0.parentNode.insertBefore(s1,s0);
        })();
    </script>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="card-header">
                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>
                <h1 class="card-heading">Payment Successful</h1>
                <p class="card-subheading">Your payment has been processed</p>
            </div>

            <div class="card-body">
                <div class="details-grid">
                    <div class="detail-item">
                        <span class="detail-label">Payment Merchant</span>
                        <span class="detail-value"><%= company_name %></span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Payment Type</span>
                        <span class="detail-value">Card</span>
                    </div>
                    <!-- <div class="detail-item">
                        <span class="detail-label">Mobile No</span>
                        <span class="detail-value" id="phone"><%= phone %></span>
                    </div> -->
                    <div class="detail-item">
                        <span class="detail-label">Email</span>
                        <span class="detail-value" id="email"><%= email %></span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Transaction ID</span>
                        <span class="detail-value">ATH23D534SA5</span>
                    </div>
                </div>

                <div class="amount-highlight">
                    <div class="amount-label">Amount Paid</div>
                    <div class="amount-value">$<span id="amount"><%= amount %></span></div>
                </div>
               
                           

                <div class="notice">
                    <strong>Important:</strong> Please note that the charge on your statement will appear as <strong><%= company_name %></strong>. If you have any questions or concerns, feel free to contact our support team at <a href="mailto:<%= email %>"><%= email %></a> or <strong><%= phone %></strong>.
                </div>
            </div>
        </div>
    </div>

    <script>
       /*  document.getElementById("phone").innerText = localStorage.getItem("phone") || "+1(408) 580-5952";
        document.getElementById("email").innerText = localStorage.getItem("Email") || "xyz@example.com"; */
      /*   document.getElementById("amount").innerText = localStorage.getItem("Amount") || "0.00"; */
        document.getElementById("generate-invoice-button").addEventListener('click', downloadInvoice);

        function getFormattedDate() {
            const today = new Date();
            const day = String(today.getDate()).padStart(2, '0');
            const month = String(today.getMonth() + 1).padStart(2, '0');
            const year = today.getFullYear();
            return `${day}-${month}-${year}`;
        }

        function getSampleData() {
            return {
                images: {
                    logo: 'https://i.ibb.co/cjyLbrb/Chat-GPT-Image-Dec-3-2025-10-08-07-AM.png'
                },
                sender: {
                    company: '<%= company_name %>',
                    country: 'United States'
                },
                client: {
                    company: "<%= company_name %>",
                    address: "<%= email %>",
                    zip: localStorage.getItem("PatientId") || "N/A"
                },
                information: {
                    date: getFormattedDate(),
                    number: "<%= phone %>",
                    'due-date': "NA"
                },
                products: [
                    {
                        quantity: 1,
                        description: 'Health Bill',
                        'tax-rate': 0,
                        price: "<%= amount %>"
                    }
                ],
                'bottom-notice': "Please note that the charge on your statement will appear as <%= company_name %>. If you have any questions or concerns, feel free to contact our support team at <%= email %> or <%= phone %>",
                settings: {
                    currency: 'USD'
                }
            };
        }

        function downloadInvoice() {
            const data = getSampleData();
            easyinvoice.createInvoice(data, function(result) {
                easyinvoice.download('Athenahealth_Invoice.pdf', result.pdf);
            });
        }
    </script>
</body>
</html>
