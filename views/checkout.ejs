#loader {
  display: flex;
  justify-content: center;
  align-items: center;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.5); /* semi-transparent background to overlay on the content */
  z-index: 9999; /* make sure the loader is on top of other elements */
}

#loader::before {
  content: "";
  display: block;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 4px solid #ccc;
  border-top-color: #3498db; /* set the color of the spinning animation */
  animation: spin 0.8s linear infinite; /* add the spinning animation */
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

