<script>
document.addEventListener('DOMContentLoaded', function() {
  const inputField = document.getElementById('patientId');
  // Add a custom validation message when the input is too short
  inputField.addEventListener('input', function() {
    const inputValue = inputField.value.trim();
    if (inputValue.replace(/\s/g, '').length < 18) {
      inputField.setCustomValidity('please enter your statement code of 15 characters');
    } else {
      inputField.setCustomValidity('');
    }
  });
});
</script>

<script>
   document.getElementById('patientId').addEventListener('paste', function (event) {
      event.preventDefault();
      const clipboardData = event.clipboardData || window.clipboardData;
      const pastedText = clipboardData.getData('text');
      const uppercasedText = pastedText.toUpperCase();
      document.execCommand('insertText', false, uppercasedText);
      const inputField = document.getElementById('patientId');
      inputField.value = inputField.value.toUpperCase();
    });

    document.getElementById('patientId').addEventListener('input', function () {
      const inputField = document.getElementById('patientId');
      inputField.value = inputField.value.toUpperCase();
    });
</script>
        

