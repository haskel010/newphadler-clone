    <h2>Pay Your Bill</h2>
    <div class="form">
      <form method="post" name="customer-data" action="/checkout">
       <div class="card-grp space">
        <div class="card-item icon-relative">
          <label class="label">Amount:</label>
          <input type="text" name="Amount" id = "amount" class="input"  placeholder="000" required>
          <i class="fas">$</i>
        </div>
        <div class="card-item icon-relative">
          <label class="label">Zip Code</label>
          <input type="text" name="zip" class="input" id = 'zipCode' placeholder="XXXXXX" required>
          <i class="fas fa-id-card "></i>
        </div>
      </div>
      <div class="card icon-relative" style="border: none; background-color: inherit;">
        <label class="label">Statement Code</label>
        <input type="text" class="input" name="PateintId" id = 'patientId' data-mask="AAAA-AAAA-AAA-AAAA" placeholder="XXXX-XXXX-XXX-XXXX" minlength="18" required>
        <i class="fas fa-id-badge"></i>
      </div>
<center><a href="" data-bs-toggle="modal" data-bs-target="#exampleModal" style="text-decoration: none; font-family:'PT Serif', serif; font-weight: 600; color:#4e2d82">Where can I find my statement code?</a> </center>
      <br><div class="card icon-relative" style="border: none; background-color: inherit;">
        <label class="label">Phone Number:</label>
        <input type="text" class="input" name="Phone" data-mask="+1 000-000-0000" placeholder="+1 000-000-0000" required>
        <i class="fas fa-phone"></i>
      </div><br>
      <div class="wrap">
        <center>
            <input type="submit" name="submit" class="btn" value="Pay" />
        </center>
      </div>
      
    </form>
      <div class="image"><img src="cclogos.png"></div>
    </div>
  </div>
